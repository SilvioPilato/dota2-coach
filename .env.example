# Copy this file to .env and fill in your values
ANTHROPIC_API_KEY=your-api-key-here

# Optional: Stratz API key for accurate pos 1-5 role detection.
# Get yours at https://stratz.com/api — free tier is sufficient.
# Without this, role detection falls back to the OpenDota GPM-ranking heuristic.
#STRATZ_API_KEY=your-stratz-api-key-here

# Optional: use a local LLM via LM Studio or compatible server
#LLM_MODEL=openai/qwen3.5-9b
#OPENAI_API_BASE=http://localhost:1234/v1
#OPENAI_API_KEY=lm-studio

# Default model
LLM_MODEL=anthropic/claude-sonnet-4-6
